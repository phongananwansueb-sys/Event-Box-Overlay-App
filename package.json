{
  "name": "realtime-caption-overlay",
  "version": "1.0.0",
  "description": "Real-time subtitle overlay using Electron",
  "main": "main.js",
  "scripts": {
    "start": "node_modules\\electron\\dist\\electron.exe .",
    "build": "electron-builder"
  },
  "devDependencies": {
    "electron": "^29.0.0",
    "electron-builder": "^24.0.0"
  },
  "build": {
    "appId": "com.realtimecaption.overlay",
    "productName": "RealtimeCaption Overlay",
    "files": [
      "main.js",
      "overlay.html",
      "overlay-preload.js",
      "package.json"
    ],
    "win": {
      "target": "nsis"
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false
    },
    "extraMetadata": {
      "env": {
        "SERVER_URL": "https://event-boxsx-se.onrender.com"
      }
    }
  }
}
